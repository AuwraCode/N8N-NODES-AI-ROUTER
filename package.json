{
  "name": "@auwra/n8n-nodes-ai-router",
  "version": "0.1.5",
  "description": "Automatically route AI tasks to the most appropriate and cost-effective model across multiple providers",
  "license": "MIT",
  "keywords": [
    "n8n-community-node-package"
  ],
  "author": {
    "name": "Auwra",
    "email": "grzegorzhandzel992@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AuwraCode/N8N-NODES-AI-ROUTER.git"
  },
  "homepage": "https://github.com/AuwraCode/N8N-NODES-AI-ROUTER#readme",
  "bugs": {
    "url": "https://github.com/AuwraCode/N8N-NODES-AI-ROUTER/issues"
  },
  "main": "index.js",
  "scripts": {
    "build": "n8n-node build",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:real": "node test-real/run.mjs",
    "sync:models": "node scripts/sync-models.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/AiRouterApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/AiRouter/AiRouter.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "@vitest/coverage-v8": "^3.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "eslint": "^9.0.0"
  }
}
