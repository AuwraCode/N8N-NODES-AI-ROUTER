# Copy this file to .env and fill in your API keys.
# Only the providers you configure will be tested — the rest are skipped.

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...
MISTRAL_API_KEY=
GROQ_API_KEY=gsk_...

# Optional: only needed if you want to test Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
